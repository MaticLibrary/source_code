<?xml version="1.0" encoding="UTF-8"?>

<?import com.example.settings.IntegerSettingTextField?>
<?import java.net.URL?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:id="parent"
          fx:controller="com.example.controller.settings.ZkpSettingsController" id="root">

    <stylesheets>
        <URL value="@/css/algorithmSettings.css"/>
    </stylesheets>

    <Label GridPane.columnIndex="0" GridPane.rowIndex="0" text="Maks. zdrajcow (f)" fx:id="fLabel" id="label"/>
    <IntegerSettingTextField GridPane.columnIndex="1" GridPane.rowIndex="0" fx:id="f" GridPane.hgrow="ALWAYS"/>

    <Label GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2"
           fx:id="hintLabel"
           text="Kazdy glos jest akceptowany tylko wtedy, gdy przejdzie prawdziwa weryfikacje ZKP wzgledem zobowiazania Pedersena."
           wrapText="true"
           styleClass="hint-text"/>
</GridPane>
