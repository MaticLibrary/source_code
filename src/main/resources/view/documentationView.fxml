<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane prefHeight="440.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.DocumentationController"
            styleClass="app-root docs-root panel-padding">
    <stylesheets>
        <URL value="@/css/theme.css"/>
    </stylesheets>
    <top>
        <VBox spacing="4" styleClass="docs-header">
            <Label text="Dokumentacja" styleClass="docs-title"/>
            <Label text="Praktyczny opis algorytmów i obsługi symulacji" styleClass="docs-subtitle"/>
        </VBox>
    </top>
    <left>
        <VBox spacing="8" styleClass="docs-sidebar">
            <Label text="Spis treści" styleClass="section-label"/>
            <ListView fx:id="articleList" prefHeight="360.0" prefWidth="220.0" styleClass="docs-list">
                <Label text="Symulacja" styleClass="docs-item"/>
                <Label text="Algorytm Lamporta" styleClass="docs-item"/>
                <Label text="Algorytm Króla" styleClass="docs-item"/>
                <Label text="Algorytm PBFT" styleClass="docs-item"/>
                <Label text="BFT z regułami prywatnymi" styleClass="docs-item"/>
            </ListView>
        </VBox>
    </left>
    <center>
        <VBox spacing="8" styleClass="docs-content">
            <Label text="Opis" styleClass="section-label"/>
            <AnchorPane fx:id="page" styleClass="docs-page" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
