<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<FlowPane xmlns="http://javafx.com/javafx"
          orientation="VERTICAL" vgap="20" hgap="16" prefHeight="250.0">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../legendImages/traitor.png"/>
        </ImageView>
        <Label text="Zdrajca"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../legendImages/notTraitor.png"/>
        </ImageView>
        <Label text="Agent lojalny"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../legendImages/attackOpinion.png"/>
        </ImageView>
        <Label text="Opinia: atak"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../legendImages/defendOpinion.png"/>
        </ImageView>
        <Label text="Opinia: odwrót"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../icons/sword.png"/>
        </ImageView>
        <Label text="Atak"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="25" fitHeight="25">
            <Image url="@../icons/shield.png"/>
        </ImageView>
        <Label text="Obrona"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitWidth="20" fitHeight="20">
            <Image url="@../view/images/circle-info-solid.png"/>
        </ImageView>
        <Label text="Alarm: rozbieżność reguł"/>
    </HBox>
</FlowPane>
